# pnpm 11 runs `pnpm install` before every script (verify-deps-before-run).
# That pre-run check hard-fails on unapproved native build scripts
# (esbuild/sharp/unrs-resolver) even though they're listed in
# package.json pnpm.onlyBuiltDependencies. Disable the pre-run check;
# deps are managed explicitly via `pnpm install`.
verify-deps-before-run=false
